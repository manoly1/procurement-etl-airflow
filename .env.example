# Copy to .env (which is gitignored) and adjust as needed.
# Secrets live in the environment, never in code — the deliberate contrast with
# the hardcoded Config.bas of the original project.
DATABASE_URL=postgresql+psycopg2://etl:etl@localhost:5432/procurement

# Object store (MinIO) — the raw layer. Endpoint is empty on real AWS S3.
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=procurement-raw
